---
const phases = [
  {
    title: 'Discover',
    subtitle: 'research',
    items: ['User interviews', 'Heuristic evaluation', 'Stakeholder workshops', 'Desk research'],
    tools: ['Notion', 'Maze'],
  },
  {
    title: 'Define',
    subtitle: 'synthesis',
    items: ['Personas', 'Problem framing', 'User flows', 'Information architecture'],
    tools: ['Miro', 'Trello', 'Whimsical', 'FigJam'],
  },
  {
    title: 'Develop',
    subtitle: 'design',
    items: ['Wireframes', 'Visual design', 'Prototyping', 'Component systems'],
    tools: ['Figma', 'Adobe CC', 'Affinity Suite', 'Unity'],
  },
  {
    title: 'Deliver',
    subtitle: 'code',
    items: ['Frontend development', 'Prototypes', 'Documentation', 'Design system handoff'],
    tools: ['HTML', 'CSS', 'JS', 'TS', 'Astro', 'Git'],
  },
];
---

<section class="section process" id="process" aria-label="Process">
  <div class="process-inner">
    <!-- double diamond — Discover widens, Define narrows to the brief,
         Develop widens, Deliver narrows -->
    <svg class="pr-dia" viewBox="0 0 1600 760" preserveAspectRatio="none" aria-hidden="true">
      <polygon points="0,380 400,80 800,380 400,680" pathLength="1"></polygon>
      <polygon points="800,380 1200,80 1600,380 1200,680" pathLength="1"></polygon>
    </svg>

    <h2 class="sr-only">Process</h2>

    <div class="pr-cols">
      {phases.map((phase) => (
        <div class="pr-col">
          <span class="pr-mark" aria-hidden="true"></span>
          <span class="pr-tag">{phase.subtitle}</span>
          <h3 class="pr-name">{phase.title}</h3>
          <ul class="pr-acts">
            {phase.items.map((item) => <li class="pr-act">{item}</li>)}
          </ul>
          <div class="pr-rule"></div>
          <p class="pr-tools">{phase.tools.join(' · ')}</p>
        </div>
      ))}
    </div>

    <p class="pr-statement">
      The framework above is the foundation; the reality is iterative.<br />
      I use these phases to turn user insights into clean, buildable interfaces.
    </p>
  </div>
</section>

<style>
  .process {
    width: 100vw;
    padding: 0;
    background: var(--color-bg);
  }

  .process-inner {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 8vh 5.5vw;
    overflow: hidden;
  }

  .pr-dia {
    position: absolute;
    left: 5.5vw;
    right: 5.5vw;
    top: 50%;
    height: 62%;
    transform: translateY(-54%);
    z-index: 0;
    pointer-events: none;
  }

  /* Static for now; Stage B's reveal system gates the draw-in behind .is-in. */
  .pr-dia polygon {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 1.1;
    vector-effect: non-scaling-stroke;
    opacity: 0.17;
  }

  .pr-cols {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .pr-col {
    padding: 0 clamp(22px, 2.2vw, 44px);
    transition: translate 0.4s var(--ease-out);
  }

  .pr-col:first-child {
    padding-left: 0;
  }

  .pr-col:last-child {
    padding-right: 0;
  }

  .pr-mark {
    display: block;
    width: 11px;
    height: 11px;
    margin: 0 0 22px;
    background: var(--color-accent);
    transform: rotate(45deg);
    box-shadow: 0 0 0 5px rgb(217 179 108 / 0.1);
    transition: transform 0.35s var(--ease-out), box-shadow 0.35s ease;
  }

  .pr-tag {
    display: block;
    margin: 0 0 16px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    transition: color 0.3s ease;
  }

  .pr-name {
    margin: 0 0 26px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(30px, 3.1vw, 48px);
    line-height: 1.02;
    letter-spacing: -0.015em;
    color: var(--color-text);
    transition: color 0.3s ease;
  }

  .pr-acts {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pr-act {
    padding: 7px 0;
    font-family: var(--font-body);
    font-size: 14.5px;
    line-height: 1.45;
    color: #d7d0c4;
    transition: color 0.3s ease;
  }

  .pr-act:first-child {
    padding-top: 0;
  }

  .pr-rule {
    height: 1px;
    margin: 22px 0 16px;
    background: var(--color-border);
    transition: background 0.4s ease;
  }

  .pr-tools {
    margin: 0;
    font-family: var(--font-body);
    font-size: 12.5px;
    letter-spacing: 0.02em;
    line-height: 1.6;
    color: var(--color-muted);
  }

  .pr-col:hover {
    translate: 0 -7px;
  }

  .pr-col:hover .pr-mark {
    transform: rotate(45deg) scale(1.25);
    box-shadow: 0 0 0 6px rgb(217 179 108 / 0.12), 0 0 20px rgb(217 179 108 / 0.45);
  }

  .pr-col:hover .pr-name {
    color: #fff;
  }

  .pr-col:hover .pr-rule {
    background: var(--color-accent);
  }

  .pr-col:hover .pr-tag {
    color: #e4c384;
  }

  .pr-col:hover .pr-act {
    color: #ece5d9;
  }

  .pr-statement {
    position: relative;
    z-index: 1;
    max-width: 64ch;
    margin: 9vh auto 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(16px, 1.5vw, 19px);
    line-height: 1.6;
    color: #c2bbb0;
    text-align: center;
  }

  @media (max-width: 820px), (prefers-reduced-motion: reduce) {
    .process-inner {
      position: static;
      display: block;
      padding: 16vh 7vw 12vh;
    }

    .pr-dia {
      display: none;
    }

    .pr-cols {
      grid-template-columns: 1fr 1fr;
      gap: 38px 26px;
    }

    .pr-col {
      padding: 0;
    }

    .pr-name {
      font-size: clamp(28px, 7vw, 40px);
    }

    .pr-statement {
      margin-top: 7vh;
    }
  }
</style>
