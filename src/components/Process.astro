---
const phases = [
  {
    title: 'Discover',
    subtitle: 'research',
    items: ['User interviews', 'Heuristic evaluation', 'Stakeholder workshops', 'Desk research'],
    tools: ['Notion', 'Maze'],
  },
  {
    title: 'Define',
    subtitle: 'synthesis',
    items: ['Personas', 'Problem framing', 'User flows', 'Information architecture'],
    tools: ['Miro', 'Trello', 'Whimsical', 'FigJam'],
  },
  {
    title: 'Develop',
    subtitle: 'design',
    items: ['Wireframes', 'Visual design', 'Prototyping', 'Component systems'],
    tools: ['Figma', 'Adobe CC', 'Affinity Suite', 'Unity'],
  },
  {
    title: 'Deliver',
    subtitle: 'code',
    items: ['Frontend development', 'Prototypes', 'Documentation', 'Design system handoff'],
    tools: ['HTML', 'CSS', 'JS', 'TS', 'Astro', 'Git'],
  },
];
---

<section class="section process" id="process" aria-label="Process">
  <div class="process-inner">
    <h2 class="sr-only">Process</h2>

    <!-- the diamonds live in the same box as the columns, so their tips sit
         exactly on the column boundaries and their waist on the columns'
         vertical centre — double diamond: Discover widens, Define narrows
         to the brief, Develop widens, Deliver narrows -->
    <div class="pr-grid">
      <!-- One continuous line drawn in a single stroke, "Haus vom Nikolaus"
           style. Point order (labelled left→right, top/centre/bottom):
             1 left tip · 2 peak 1 · 3 centre · 6 valley 2 · 5 right tip ·
             4 peak 2 · (3) centre · 7 valley 1 · close.
           So: over the first peak, down through the centre into the far
           valley, up the right tip, back over the second peak to the centre,
           and down to close — a flowing wave rather than two separate loops. -->
      <svg class="pr-dia" viewBox="0 0 1600 760" preserveAspectRatio="none" aria-hidden="true">
        <path
          d="M0,380 L400,80 L800,380 L1200,680 L1600,380 L1200,80 L800,380 L400,680 Z"
          pathLength="1"></path>
      </svg>

      <div class="pr-cols">
        {
          phases.map((phase, i) => (
            <div class="pr-col reveal reveal-x" style={`--i:${i}`}>
              <span class="pr-mark" aria-hidden="true" />
              <span class="pr-tag">{phase.subtitle}</span>
              <h3 class="pr-name">{phase.title}</h3>
              <ul class="pr-acts">
                {phase.items.map((item) => (
                  <li class="pr-act">{item}</li>
                ))}
              </ul>
              <p class="pr-tools">{phase.tools.join(' · ')}</p>
            </div>
          ))
        }
      </div>
    </div>

    <p class="pr-statement reveal reveal-rise" style="--i:4">
      The framework above is the foundation; the reality is iterative.<br />
      I use these phases to turn user insights into clean, buildable interfaces.
    </p>
  </div>
</section>

<style>
  .process {
    width: 100vw;
    padding: 0;
    background: var(--color-bg);
  }

  .process-inner {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 8vh 5.5vw;
    overflow: hidden;
  }

  .pr-grid {
    position: relative;
  }

  /* anchored to the columns' box: tips on the column boundaries, waist on
     their vertical centre, peaks reaching a little beyond the text.
     width must be explicit: as a replaced element an absolutely positioned
     SVG may resolve its width from the viewBox aspect ratio instead of the
     left/right stretch — on wide screens that left it ~40% too narrow and
     the whole figure misaligned. */
  .pr-dia {
    position: absolute;
    left: 0;
    top: 50%;
    display: block;
    width: 100%;
    height: 132%;
    transform: translateY(-50%);
    z-index: 0;
    pointer-events: none;
  }

  /* The line draws itself in one continuous stroke — but only once the
     visitor has actually arrived on the panel (.is-centred, not the early
     .is-in), so the drawing is never half-missed while reading the previous
     panel. pathLength="1" normalises the dash to the whole outline so the
     single offset animation traces it end to end. Without JS or with
     reduced motion it is simply visible. */
  .pr-dia path {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 1.1;
    vector-effect: non-scaling-stroke;
    opacity: 0.24;
  }

  :global(html.js) .pr-dia path {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    opacity: 0;
    transition:
      stroke-dashoffset 4.2s cubic-bezier(0.4, 0, 0.18, 1),
      opacity 0.9s ease;
  }

  :global(html.js) .process.is-centred .pr-dia path {
    stroke-dashoffset: 0;
    opacity: 0.17;
  }

  @media (prefers-reduced-motion: reduce) {
    :global(html.js) .pr-dia path {
      stroke-dasharray: none;
      stroke-dashoffset: 0;
      opacity: 0.17;
      transition: none;
    }
  }

  .pr-cols {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  /* hover-lift transition rides on the .reveal primitive (translate 0.45s),
     so the column's own transition must not shadow the reveal transition */
  .pr-col {
    padding: 0 clamp(22px, 2.2vw, 44px);
  }

  .pr-col:first-child {
    padding-left: 0;
  }

  .pr-col:last-child {
    padding-right: 0;
  }

  .pr-mark {
    display: block;
    width: 11px;
    height: 11px;
    margin: 0 0 22px;
    background: var(--color-accent);
    transform: rotate(45deg);
    box-shadow: 0 0 0 5px rgb(217 179 108 / 0.1);
  }

  .pr-tag {
    display: block;
    margin: 0 0 16px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    transition: color 0.3s ease;
  }

  .pr-name {
    margin: 0 0 26px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(30px, 3.1vw, 48px);
    line-height: 1.02;
    letter-spacing: -0.015em;
    color: var(--color-text);
    transition: color 0.3s ease;
  }

  .pr-acts {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pr-act {
    padding: 7px 0;
    font-family: var(--font-body);
    font-size: 14.5px;
    line-height: 1.45;
    color: #d7d0c4;
    transition: color 0.3s ease;
  }

  .pr-act:first-child {
    padding-top: 0;
  }

  /* tools sit in the brand gold permanently — they read as the phase's
     toolkit, and the gold ties the four columns together under the diamond.
     No separator rule: it crossed the drawn diamond line and added clutter.
     The columns carry no hover state — they are a static reference, not a
     control (the work cards own the clickable affordance). */
  .pr-tools {
    margin: 32px 0 0;
    font-family: var(--font-body);
    font-size: 12.5px;
    letter-spacing: 0.02em;
    line-height: 1.6;
    color: var(--color-accent);
  }

  .pr-statement {
    position: relative;
    z-index: 1;
    max-width: 64ch;
    margin: 9vh auto 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(16px, 1.5vw, 19px);
    line-height: 1.6;
    color: #c2bbb0;
    text-align: center;
  }

  @media (max-width: 820px), (prefers-reduced-motion: reduce) {
    .process-inner {
      position: static;
      display: block;
      padding: 16vh 7vw 12vh;
    }

    .pr-dia {
      display: none;
    }

    .pr-cols {
      grid-template-columns: 1fr 1fr;
      gap: 38px 26px;
    }

    .pr-col {
      padding: 0;
    }

    .pr-name {
      font-size: clamp(28px, 7vw, 40px);
    }

    .pr-statement {
      margin-top: 7vh;
    }
  }
</style>
