---
import { Picture } from 'astro:assets';
import contactPhoto from '../assets/images/contact.jpg';

// Email is assembled client-side so the literal address never appears as a
// contiguous "user@domain" string in the served HTML (basic crawler defence).
const mailUser = 'valentin.lenzing';
const mailDomain = 'gmail.com';
---

<section class="section contact" id="contact" aria-label="Contact">
  <div class="c-inner">
    <div class="c-left">
      <figure class="cphoto reveal reveal-x" style="--i:0">
        <Picture
          src={contactPhoto}
          formats={['avif', 'webp']}
          quality={80}
          alt="Valentin Lenzing"
          widths={[360, 540, 720, 900]}
          sizes="(max-width: 820px) 86vw, 380px"
          loading="eager"
        />
      </figure>
      <p class="cquote reveal" style="--i:2">
        &ldquo;Ever since I was young, I wanted to optimize cross-functional
        communication frameworks and streamline end-to-end user journeys.&rdquo;
      </p>
    </div>

    <div class="c-right">
      <div class="cgroup reveal" style="--i:0">
        <p class="clabel">Email</p>
        <a
          class="cmail"
          data-mail-user={mailUser}
          data-mail-domain={mailDomain}
          aria-label="Email Valentin Lenzing"
        >
          <span data-mail-text>{mailUser} [at] {mailDomain}</span>
        </a>
      </div>

      <div class="cgroup reveal" style="--i:1">
        <p class="clabel">Elsewhere</p>
        <p class="clinks">
          <a class="clink" href="https://www.linkedin.com/in/valentinlenzing" target="_blank" rel="noopener noreferrer">
            LinkedIn <span class="clink-arrow" aria-hidden="true">&#8599;</span>
          </a>
          <span class="clink-sep" aria-hidden="true">&middot;</span>
          <a class="clink" href="https://github.com/vlnzng" target="_blank" rel="noopener noreferrer">
            GitHub <span class="clink-arrow" aria-hidden="true">&#8599;</span>
          </a>
        </p>
      </div>

      <div class="cgroup cmeta-row reveal" style="--i:2">
        <div class="cmeta-item">
          <p class="clabel">Based in</p>
          <p class="cmeta-value">Berlin Metropolitan Area</p>
          <p class="cmeta-sub">Open to relocate</p>
        </div>
        <div class="cmeta-item">
          <p class="clabel">Status</p>
          <p class="cmeta-value">Available immediately</p>
          <p class="cmeta-sub">Full-time</p>
        </div>
      </div>
    </div>
  </div>

  <nav class="clegal" aria-label="Legal">
    <a class="clegal-link" href="/imprint">Legal Notice</a>
    <span class="clegal-dot" aria-hidden="true">&middot;</span>
    <a class="clegal-link" href="/privacy">Privacy Policy</a>
  </nav>
</section>

<script>
  const link = document.querySelector<HTMLAnchorElement>('.cmail[data-mail-user]');
  if (link) {
    const user = link.dataset.mailUser ?? '';
    const domain = link.dataset.mailDomain ?? '';
    const address = `${user}@${domain}`;
    link.href = `mailto:${address}`;
    const text = link.querySelector<HTMLElement>('[data-mail-text]');
    if (text) text.textContent = address;
  }

  // Remember the scroll position when leaving for a legal page, so returning
  // lands exactly where the link was clicked (restored in scroll.ts on load).
  document.querySelectorAll<HTMLAnchorElement>('.clegal a').forEach((a) => {
    a.addEventListener('click', () => {
      try {
        sessionStorage.setItem('vl:returnY', String(window.scrollY));
      } catch {
        /* sessionStorage unavailable — fall back to the #contact hash */
      }
    });
  });
</script>

<style>
  .contact {
    width: 100vw;
    padding: 0;
    background: var(--color-bg);
  }

  /* two-column layout: framed photo + quote · contact info. Shares the
     5.5vw gutter of the other panels so the pan rhythm stays even — the
     gap to the previous section reads like every other section break. */
  .c-inner {
    position: absolute;
    inset: 0;
    z-index: 3;
    padding: 0 5.5vw;
    display: grid;
    grid-template-columns: clamp(290px, 30vw, 380px) 1fr;
    align-items: center;
    gap: clamp(56px, 7vw, 120px);
  }

  /* the whole left block (photo + quote) is one hover zone — the effect is
     the same wherever inside it the cursor rests */
  .c-left {
    min-width: 0;
  }

  /* ---- framed photo with a gold light that travels on hover ---- */
  @property --c-frame-rot {
    syntax: '<angle>';
    inherits: false;
    initial-value: 0deg;
  }

  .cphoto {
    --frame-w: 3px;
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    margin: 0;
    overflow: hidden;
    background: var(--color-surface);
    /* slow build-up — the glow grows in rather than switching on */
    transition: box-shadow 1.7s var(--ease-glide);
  }

  /* soft gold glow on hover — quiet, elegant */
  .c-left:hover .cphoto {
    box-shadow: 0 0 30px rgb(217 179 108 / 0.2);
  }

  .cphoto picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .cphoto img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  /* the static frame and the moving light share one masked ring */
  .cphoto::before,
  .cphoto::after {
    content: '';
    position: absolute;
    inset: 0;
    padding: var(--frame-w);
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  /* visible static gold frame — brightens first on hover */
  .cphoto::before {
    background: rgb(217 179 108 / 0.6);
    z-index: 2;
    transition: background 1.2s ease;
  }

  .c-left:hover .cphoto::before {
    background: rgb(217 179 108 / 0.82);
  }

  /* a soft gold light that drifts slowly around the frame on hover */
  .cphoto::after {
    background: conic-gradient(
      from var(--c-frame-rot),
      transparent 0deg,
      rgb(245 224 175 / 0) 30deg,
      rgb(245 224 175 / 0.35) 60deg,
      rgb(255 240 208 / 0.7) 90deg,
      rgb(245 224 175 / 0.35) 120deg,
      rgb(245 224 175 / 0) 150deg,
      transparent 360deg
    );
    opacity: 0;
    /* the travelling light is the last layer to arrive */
    transition: opacity 1.9s ease 0.3s;
    z-index: 3;
  }

  .c-left:hover .cphoto::after {
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .c-left:hover .cphoto::after {
      animation: c-frame-spin 9.5s linear infinite;
    }
  }

  @keyframes c-frame-spin {
    to {
      --c-frame-rot: 360deg;
    }
  }

  .cquote {
    margin: clamp(20px, 2vw, 30px) 0 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(14.5px, 1.05vw, 17px);
    line-height: 1.5;
    color: var(--color-muted);
    max-width: 40ch;
    transition: color 0.9s ease, text-shadow 0.9s ease;
  }

  /* the quote wakes up with the same hover — it is part of the zone */
  .c-left:hover .cquote {
    color: var(--color-text);
    text-shadow: 0 0 16px rgb(217 179 108 / 0.18);
  }

  /* ---- right: contact info ---- */
  /* centres itself in the room left of the photo, so the free space splits
     evenly instead of pooling at the right edge */
  .c-right {
    min-width: 0;
    max-width: 640px;
    width: 100%;
    margin-inline: auto;
  }

  .cgroup + .cgroup {
    margin-top: 26px;
    padding-top: 26px;
    border-top: 1px solid var(--color-border);
  }

  .clabel {
    margin: 0 0 14px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  /* email — the hero of this panel; sized to keep the address on one line */
  .cmail {
    display: inline-block;
    position: relative;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(20px, 2.2vw, 34px);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
  }

  /* a soft underline draws itself once the panel arrives… */
  :global(html.js) .cmail::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -7px;
    height: 2px;
    background: rgb(217 179 108 / 0.34);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.9s var(--ease-glide) 0.25s;
  }

  :global(html.js) .contact.is-in .cmail::before {
    transform: scaleX(1);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(html.js) .cmail::before {
      transform: scaleX(1);
      transition: none;
    }
  }

  /* …and the full-strength hover underline sits on top of it */
  .cmail::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -7px;
    height: 2px;
    background: rgb(217 179 108 / 0.38);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.45s var(--ease-out), background 0.3s ease;
  }

  .cmail:hover {
    color: var(--color-accent);
  }

  .cmail:hover::after {
    transform: scaleX(1);
    background: var(--color-accent);
  }

  .clinks {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 0;
  }

  .clink {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 16px;
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  .clink-arrow {
    color: var(--color-accent);
    font-size: 14px;
    transition: transform 0.25s var(--ease-out);
  }

  .clink-sep {
    color: var(--color-border);
    font-size: 14px;
  }

  .clink:hover {
    color: var(--color-accent);
  }

  .clink:hover .clink-arrow {
    transform: translate(3px, -3px);
  }

  /* based in / status — side by side, gold values, no pulsing dot */
  .cmeta-row {
    display: flex;
    gap: clamp(40px, 5vw, 72px);
    flex-wrap: wrap;
  }

  .cmeta-value {
    margin: 0;
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.4;
    color: var(--color-text);
  }

  .cmeta-sub {
    margin: 5px 0 0;
    font-family: var(--font-body);
    font-size: 12.5px;
    line-height: 1.3;
    color: var(--color-muted);
  }

  /* vertical legal at the right edge */
  .clegal {
    position: absolute;
    right: 26px;
    top: 50%;
    z-index: 50;
    transform: translateY(-50%) rotate(180deg);
    writing-mode: vertical-rl;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .clegal-link {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 11.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
    transition: color 0.2s ease;
  }

  .clegal-link:hover {
    color: var(--color-accent);
  }

  .clegal-dot {
    color: var(--color-border);
    font-size: 11px;
  }

  @media (max-width: 820px), (prefers-reduced-motion: reduce) {
    .contact {
      min-height: auto;
    }

    .c-inner {
      position: static;
      display: block;
      max-width: none;
      margin: 0;
      padding: 14vh 7vw 8vh;
    }

    .cphoto {
      max-width: 340px;
    }

    .cquote {
      max-width: none;
    }

    .c-right {
      margin-top: 9vh;
      max-width: none;
    }

    .cmail {
      font-size: clamp(18px, 5.2vw, 28px);
      white-space: normal;
    }

    .clegal {
      position: static;
      transform: none;
      writing-mode: horizontal-tb;
      justify-content: flex-start;
      padding: 2vh 7vw 12vh;
    }
  }
</style>
