---
const encodedMail = 'hello&#64;valentin-lenzing.de';
---

<section class="section contact" id="contact" aria-label="Contact">
  <figure class="contact__visual" aria-label="Desk or secondary portrait image">
    <img
      src="/images/contact-visual.webp"
      alt=""
      loading="lazy"
      decoding="async"
      onerror="this.hidden=true"
    />
  </figure>

  <p class="contact__line">
    Get in touch,<br />
    whether it's a job,<br />
    a question, or just<br />
    a hello.
  </p>

  <div class="contact__panel">
    <a
      class="contact__mail"
      href="#contact"
      data-mail-link
      data-mail-user="hello"
      data-mail-domain="valentin-lenzing.de"
    >
      <span set:html={encodedMail}></span>
    </a>

    <div class="contact__links">
      <a href="https://linkedin.com/in/valentin-lenzing" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="https://github.com/vlnzng" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>

    <div class="contact__status">
      <p>Brandenburg, Germany</p>
      <p>Available immediately</p>
    </div>

    <div class="contact__cv" aria-label="CV downloads">
      <a href="/cv/valentin-lenzing-cv-de.pdf">CV (DE)</a>
      <a href="/cv/valentin-lenzing-cv-en.pdf">CV (EN)</a>
    </div>
  </div>

  <nav class="contact__legal" aria-label="Legal">
    <a href="/imprint">Imprint</a>
    <a href="/privacy">Privacy</a>
  </nav>
</section>

<script>
  const mailLink = document.querySelector<HTMLAnchorElement>('[data-mail-link]');
  if (mailLink) {
    const address = `${mailLink.dataset.mailUser}@${mailLink.dataset.mailDomain}`;
    mailLink.href = `mailto:${address}`;
  }
</script>

<style>
  .contact {
    display: grid;
    grid-template-columns: minmax(18rem, 36vw) minmax(20rem, 34rem);
    grid-template-rows: 1fr auto;
    align-items: center;
    gap: var(--space-7);
  }

  .contact__visual {
    align-self: stretch;
    min-height: min(68vh, 45rem);
    overflow: hidden;
    background:
      linear-gradient(160deg, rgb(217 179 108 / 0.18), transparent 50%),
      linear-gradient(180deg, var(--color-surface), #151311);
    border: 1px solid var(--color-border);
  }

  .contact__visual img {
    width: 100%;
    height: 100%;
    min-height: inherit;
    display: block;
    object-fit: cover;
  }

  .contact__line {
    position: absolute;
    left: var(--section-padding);
    bottom: var(--section-padding);
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 4.7rem);
    font-weight: 700;
    line-height: 1;
    color: var(--color-text);
  }

  .contact__panel {
    display: grid;
    gap: var(--space-5);
  }

  .contact__mail {
    width: fit-content;
    font-size: clamp(1.35rem, 2vw, 2rem);
    color: var(--color-text);
    border-bottom: 1px solid currentColor;
    text-decoration: none;
  }

  .contact__links,
  .contact__status,
  .contact__cv {
    display: grid;
    gap: var(--space-3);
  }

  .contact__links a,
  .contact__cv a {
    width: fit-content;
    color: var(--color-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .contact__links a:hover,
  .contact__cv a:hover,
  .contact__legal a:hover,
  .contact__mail:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .contact__status {
    color: var(--color-text);
  }

  .contact__cv {
    grid-template-columns: repeat(2, max-content);
  }

  .contact__cv a {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
  }

  .contact__legal {
    position: absolute;
    right: var(--space-4);
    top: 50%;
    display: flex;
    gap: var(--space-4);
    writing-mode: vertical-rl;
    transform: translateY(-50%);
    font-size: var(--size-xs);
    color: var(--color-muted);
  }

  @media (max-width: 840px) {
    .contact {
      grid-template-columns: 1fr;
      gap: var(--space-5);
      padding-bottom: 9rem;
    }

    .contact__visual {
      min-height: 36vh;
    }

    .contact__line {
      position: relative;
      left: auto;
      bottom: auto;
    }

    .contact__legal {
      right: auto;
      left: var(--section-padding);
      top: auto;
      bottom: var(--space-4);
      writing-mode: horizontal-tb;
      transform: none;
    }
  }
</style>
