---
// One fixed portrait that belongs to no panel. It rests on the RIGHT during
// the hero and GLIDES to the LEFT as the page pans into About — the same
// cut-out (freisteller) carrying you through the transition. Because it's a
// transparent PNG it floats directly on the page: no background box, a soft
// warm glow as a halo behind, and the lower edge dissolving into the bg.
// scroll.ts drives left / width / transform from the pan progress.
import { Picture } from 'astro:assets';
import portrait from '../assets/images/portrait.png';
---

<div class="portrait" aria-hidden="true" data-portrait>
  <div class="portrait__glow"></div>
  <Picture
    src={portrait}
    formats={['avif', 'webp']}
    quality={80}
    alt=""
    widths={[960, 1440, 1920, 2560]}
    sizes="(max-width: 820px) 72vw, 52vw"
    loading="eager"
    fetchpriority="high"
  />
  <div class="portrait__fade portrait__fade--b"></div>
</div>

<style>
  .portrait {
    position: fixed;
    top: 0;
    left: 50vw;
    width: 52vw;
    height: 100vh;
    z-index: 30;
    /* transparent: the cut-out floats directly on the page, no background box */
    will-change: left, width, transform;
  }

  .portrait img {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: 50% 14%;
  }

  /* soft warm halo behind the cut-out (sits below the figure) */
  .portrait__glow {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: radial-gradient(56% 52% at 50% 32%, rgb(217 179 108 / 0.13), transparent 70%);
  }

  /* lower edge dissolves into the page so the torso isn't hard-cut */
  .portrait__fade--b {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 14%;
    z-index: 3;
    pointer-events: none;
    background: linear-gradient(0deg, var(--color-bg), rgb(26 24 22 / 0));
  }

  @media (max-width: 820px), (prefers-reduced-motion: reduce) {
    /* a static hero cut-out on the right that scrolls away with the page */
    .portrait {
      position: absolute;
      left: auto;
      right: 0;
      top: 8vh;
      width: 72%;
      height: 54vh;
      transform: none !important;
    }
  }
</style>
