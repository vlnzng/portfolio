---
import type { CollectionEntry } from 'astro:content';

interface Props {
  showcase: CollectionEntry<'showcases'>;
}

const { showcase } = Astro.props;
const { title, subtitle, cardMeta, tags, order, heroImage } = showcase.data;
const slug = showcase.id.replace(/\.mdx$/, '').split('/').pop() ?? showcase.id;
---

<article
  class={`showcase-card showcase-card--${order}`}
  data-slug={slug}
  role="button"
  tabindex="0"
  aria-haspopup="dialog"
  aria-label={`Open case study: ${title}`}
>
  <figure class="showcase-card__media" aria-hidden="true">
    <img src={heroImage} alt="" loading="lazy" decoding="async" onerror="this.hidden=true" />
  </figure>

  <div class="showcase-card__content">
    <h3 class="showcase-card__title">{title}</h3>
    <p class="showcase-card__subtitle">{subtitle}</p>
    <p class="showcase-card__meta">
      {cardMeta.map((item, index) => (
        <>
          <span>{item}</span>
          {index < cardMeta.length - 1 && <span aria-hidden="true"> &middot; </span>}
        </>
      ))}
    </p>
    <p class="showcase-card__tags" aria-label="Tags">
      {tags.map((tag, index) => (
        <>
          <span>{tag}</span>
          {index < tags.length - 1 && <span class="showcase-card__separator" aria-hidden="true">&middot;</span>}
        </>
      ))}
    </p>
  </div>
</article>

<style>
  .showcase-card {
    cursor: pointer;
    min-height: 32rem;
    display: grid;
    grid-template-columns: 45% 1fr;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    outline: none;
    overflow: hidden;
    transition:
      transform var(--duration-base) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .showcase-card:hover,
  .showcase-card:focus-visible {
    transform: translateY(-0.5rem);
    border-color: var(--color-accent);
  }

  .showcase-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  .showcase-card__media {
    position: relative;
    min-height: 100%;
    overflow: hidden;
    background:
      linear-gradient(145deg, rgb(217 179 108 / 0.18), transparent 55%),
      linear-gradient(180deg, #302b26, #141210);
    border-right: 1px solid var(--color-border);
  }

  .showcase-card__media::before,
  .showcase-card__media::after {
    content: "";
    position: absolute;
    pointer-events: none;
  }

  .showcase-card__media::before {
    inset: 15%;
    border: 1px solid rgb(237 230 217 / 0.14);
  }

  .showcase-card__media::after {
    left: var(--space-4);
    right: var(--space-4);
    bottom: var(--space-4);
    height: 1px;
    background: rgb(217 179 108 / 0.55);
  }

  .showcase-card__media img {
    width: 100%;
    height: 100%;
    min-height: inherit;
    display: block;
    object-fit: cover;
  }

  .showcase-card__content {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--space-4);
    padding: var(--space-5);
  }

  .showcase-card__title {
    max-width: 13ch;
    font-size: clamp(2rem, 3vw, 3.3rem);
    font-weight: 700;
    color: var(--color-text);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .showcase-card:hover .showcase-card__title {
    color: var(--color-accent);
  }

  .showcase-card__subtitle {
    font-size: var(--size-base);
    line-height: var(--leading-normal);
    color: var(--color-muted);
  }

  .showcase-card__meta {
    font-size: var(--size-sm);
    color: var(--color-text);
  }

  .showcase-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0 var(--space-2);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    font-size: var(--size-xs);
    color: var(--color-accent);
  }

  .showcase-card__separator {
    color: var(--color-muted);
  }

  .showcase-card--2,
  .showcase-card--4 {
    grid-template-columns: 1fr 45%;
  }

  .showcase-card--2 .showcase-card__media,
  .showcase-card--4 .showcase-card__media {
    order: 2;
    border-right: 0;
    border-left: 1px solid var(--color-border);
  }

  @media (max-width: 760px) {
    .showcase-card,
    .showcase-card--2,
    .showcase-card--4 {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .showcase-card__media,
    .showcase-card--2 .showcase-card__media,
    .showcase-card--4 .showcase-card__media {
      order: 0;
      min-height: 14rem;
      border-left: 0;
      border-right: 0;
      border-bottom: 1px solid var(--color-border);
    }
  }
</style>
