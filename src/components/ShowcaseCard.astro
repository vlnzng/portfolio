---
import type { CollectionEntry } from 'astro:content';

interface Props {
  showcase: CollectionEntry<'showcases'>;
}

const { showcase } = Astro.props;
const { title, subtitle, cardMeta, tags, order } = showcase.data;
const slug = showcase.id.replace(/\.mdx$/, '').split('/').pop() ?? showcase.id;
---

<article
  class={`showcase-card showcase-card--${order}`}
  data-slug={slug}
  role="button"
  tabindex="0"
  aria-haspopup="dialog"
  aria-label={`Open case study: ${title}`}
>
  <div class="showcase-card__visual" aria-hidden="true">
    <span class="showcase-card__number">{String(order).padStart(2, '0')}</span>
  </div>

  <div class="showcase-card__content">
    <h3 class="showcase-card__title">{title}</h3>
    <p class="showcase-card__subtitle">{subtitle}</p>
    <p class="showcase-card__meta">{cardMeta}</p>
    <div class="showcase-card__tags" aria-label="Tags">
      {tags.map((tag) => <span>{tag}</span>)}
    </div>
  </div>
</article>

<style>
  .showcase-card {
    cursor: pointer;
    min-height: 32rem;
    display: grid;
    grid-template-columns: 45% 1fr;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    outline: none;
    overflow: hidden;
    transition:
      transform var(--duration-base) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .showcase-card:hover,
  .showcase-card:focus-visible {
    transform: translateY(-0.5rem);
    border-color: var(--color-accent);
  }

  .showcase-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  .showcase-card__visual {
    position: relative;
    min-height: 100%;
    background:
      linear-gradient(145deg, rgb(217 179 108 / 0.22), transparent 55%),
      linear-gradient(180deg, #302b26, #141210);
    border-right: 1px solid var(--color-border);
  }

  .showcase-card__visual::before,
  .showcase-card__visual::after {
    content: "";
    position: absolute;
    border: 1px solid rgb(237 230 217 / 0.16);
  }

  .showcase-card__visual::before {
    inset: 16%;
  }

  .showcase-card__visual::after {
    inset: 32% 18%;
    transform: rotate(45deg);
  }

  .showcase-card__number {
    position: absolute;
    left: var(--space-4);
    bottom: var(--space-4);
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 6rem);
    font-weight: 700;
    color: rgb(237 230 217 / 0.12);
  }

  .showcase-card__content {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--space-4);
    padding: var(--space-5);
  }

  .showcase-card__title {
    max-width: 13ch;
    font-size: clamp(2rem, 3vw, 3.3rem);
    font-weight: 700;
    color: var(--color-text);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .showcase-card:hover .showcase-card__title {
    color: var(--color-accent);
  }

  .showcase-card__subtitle {
    font-size: var(--size-base);
    line-height: var(--leading-normal);
    color: var(--color-muted);
  }

  .showcase-card__meta {
    font-size: var(--size-sm);
    color: var(--color-text);
  }

  .showcase-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .showcase-card__tags span {
    font-size: var(--size-xs);
    color: var(--color-accent);
  }

  .showcase-card--2,
  .showcase-card--4 {
    grid-template-columns: 1fr 45%;
  }

  .showcase-card--2 .showcase-card__visual,
  .showcase-card--4 .showcase-card__visual {
    order: 2;
    border-right: 0;
    border-left: 1px solid var(--color-border);
  }

  @media (max-width: 760px) {
    .showcase-card,
    .showcase-card--2,
    .showcase-card--4 {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .showcase-card__visual,
    .showcase-card--2 .showcase-card__visual,
    .showcase-card--4 .showcase-card__visual {
      order: 0;
      min-height: 14rem;
      border-left: 0;
      border-right: 0;
      border-bottom: 1px solid var(--color-border);
    }
  }
</style>
