---
// src/components/ShowcaseCard.astro
// Wiederverwendbare Karte für jeden Showcase.
// Klick öffnet das Modal via modal.ts und updated die URL.

import type { CollectionEntry } from 'astro:content';

interface Props {
  showcase: CollectionEntry<'showcases'>;
}

const { showcase } = Astro.props;
const { title, subtitle, year, role, tags, heroImage } = showcase.data;
const slug = showcase.slug;
---

<article
  class="showcase-card"
  data-slug={slug}
  role="button"
  tabindex="0"
  aria-haspopup="dialog"
  aria-label={`Open case study: ${title}`}
>

  <div class="showcase-card__image-wrapper">
    <!-- Bild wird hier eingesetzt sobald Astro Image Component verfügbar -->
    <div class="showcase-card__image-placeholder" aria-hidden="true"></div>
  </div>

  <footer class="showcase-card__meta">

    <div class="showcase-card__tags" aria-label="Tags">
      {tags.map((tag) => (
        <span class="showcase-card__tag">{tag}</span>
      ))}
    </div>

    <h3 class="showcase-card__title">{title}</h3>
    <p class="showcase-card__subtitle">{subtitle}</p>

    <div class="showcase-card__footer">
      <span class="showcase-card__year">{year}</span>
      <span class="showcase-card__cta" aria-hidden="true">View case →</span>
    </div>

  </footer>

</article>

<style>
  .showcase-card {
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    height: 100%;
    outline: none;
  }

  .showcase-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 2px;
  }

  .showcase-card__image-wrapper {
    flex: 1;
    overflow: hidden;
    background-color: var(--color-surface);
  }

  .showcase-card__image-placeholder {
    width: 100%;
    height: 100%;
    min-height: 300px;
    background-color: var(--color-surface);
    /* Wird durch echtes Bild ersetzt */
  }

  .showcase-card__meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .showcase-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .showcase-card__tag {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    padding: 2px var(--space-2);
  }

  .showcase-card__title {
    font-family: var(--font-display);
    font-size: var(--size-2xl);
    font-weight: 300;
    line-height: var(--leading-tight);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .showcase-card:hover .showcase-card__title {
    color: var(--color-accent);
  }

  .showcase-card__subtitle {
    font-size: var(--size-sm);
    color: var(--color-muted);
    max-width: 45ch;
  }

  .showcase-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--space-2);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
  }

  .showcase-card__year {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    color: var(--color-muted);
  }

  .showcase-card__cta {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    transition: letter-spacing var(--duration-fast) var(--ease-out);
  }

  .showcase-card:hover .showcase-card__cta {
    letter-spacing: 0.1em;
  }
</style>
