---
import type { CollectionEntry } from 'astro:content';

interface Props {
  showcase: CollectionEntry<'showcases'>;
}

const { showcase } = Astro.props;
const { title, subtitle, result, cardMeta, tags, order } = showcase.data;
const slug = showcase.id.replace(/\.mdx$/, '').split('/').pop() ?? showcase.id;
const num = String(order).padStart(2, '0');
---

<button
  class="showcase-card wcard"
  data-slug={slug}
  type="button"
  aria-haspopup="dialog"
  aria-label={`Open case study: ${title}`}
>
  <div class="wcard-media">
    <div class="wcard-media-inner">
      <div class="wstripe"></div>
      <span class="wcard-cap">project key image</span>
    </div>
  </div>

  <span class="wcard-num">{num}</span>
  <h3 class="wcard-title">{title}</h3>
  <p class="wcard-hook">{subtitle}</p>
  {result && <p class="wcard-result">{result}</p>}

  <div class="wcard-foot">
    <p class="wcard-meta">{cardMeta.join(' · ')}</p>
    <ul class="wcard-tags">
      {tags.map((tag) => <li class="wcard-tag">{tag}</li>)}
    </ul>
  </div>
</button>

<style>
  /* Work card — faithful port of the design handoff .wcard: image-top,
     enumerated, with a gold-diamond outcome line. Hover lifts + zooms. */
  .wcard {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 0;
    text-align: left;
    background: none;
    border: 0;
    padding: 0;
    color: inherit;
    font: inherit;
    cursor: pointer;
    transition: transform 0.45s var(--ease-out);
    will-change: transform;
  }

  .wcard:hover {
    transform: translateY(-10px);
  }

  .wcard:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 8px;
  }

  .wcard-media {
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
    flex: 0 0 auto;
    height: clamp(260px, 40vh, 400px);
  }

  .wcard-media-inner {
    position: absolute;
    inset: 0;
    transition: transform 0.6s var(--ease-out);
  }

  .wcard:hover .wcard-media-inner {
    transform: scale(1.05);
  }

  .wstripe {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      -45deg,
      transparent 0 16px,
      rgb(155 149 144 / 0.06) 16px 32px
    );
  }

  .wcard-cap {
    position: absolute;
    left: 16px;
    bottom: 14px;
    z-index: 1;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.04em;
    color: var(--color-muted);
  }

  .wcard-num {
    display: block;
    width: 100%;
    margin: 20px 0 0;
    padding-top: 14px;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    transition: border-color 0.25s ease;
  }

  .wcard:hover .wcard-num {
    border-color: rgb(217 179 108 / 0.5);
  }

  .wcard-title {
    margin: 10px 0 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(18px, 1.35vw, 21px);
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: var(--color-text);
    transition: color 0.25s ease;
  }

  .wcard:hover .wcard-title {
    color: #fff;
  }

  .wcard-hook {
    margin: 11px 0 0;
    max-width: none;
    font-family: var(--font-body);
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--color-muted);
  }

  /* outcome line — surfaces the result up onto the card, with a gold diamond */
  .wcard-result {
    display: flex;
    align-items: center;
    gap: 9px;
    margin: 14px 0 0;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.015em;
    color: var(--color-accent);
  }

  .wcard-result::before {
    content: "";
    width: 6px;
    height: 6px;
    flex: 0 0 auto;
    background: var(--color-accent);
    transform: rotate(45deg);
    box-shadow: 0 0 0 3px rgb(217 179 108 / 0.1);
    transition: box-shadow 0.3s ease;
  }

  .wcard:hover .wcard-result::before {
    box-shadow: 0 0 0 4px rgb(217 179 108 / 0.18), 0 0 12px rgb(217 179 108 / 0.4);
  }

  .wcard-foot {
    margin-top: 18px;
  }

  .wcard-meta {
    margin: 0 0 12px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .wcard-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .wcard-tag {
    padding: 4px 12px;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.03em;
    color: var(--color-muted);
    transition: color 0.25s ease, border-color 0.25s ease;
  }

  .wcard:hover .wcard-tag {
    color: var(--color-accent);
    border-color: rgb(217 179 108 / 0.55);
  }

  @media (max-width: 820px), (prefers-reduced-motion: reduce) {
    .wcard-media {
      height: 56vw;
      min-height: 220px;
    }
  }
</style>
