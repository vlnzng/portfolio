---
---

<div
  class="modal"
  id="showcase-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
  aria-hidden="true"
>
  <div class="modal__backdrop" id="modal-backdrop" aria-hidden="true"></div>

  <article class="modal__panel">
    <header class="modal__header">
      <div class="modal__intro" id="modal-meta"></div>
      <button class="modal__close" id="modal-close" aria-label="Close case study" type="button">
        ×
      </button>
    </header>

    <div class="modal__body" id="modal-body" tabindex="-1"></div>

    <footer class="modal__footer" id="modal-footer"></footer>
  </article>
</div>

<style>
  .modal {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal);
    display: grid;
    place-items: center;
    visibility: hidden;
    pointer-events: none;
  }

  .modal[aria-hidden="false"] {
    visibility: visible;
    pointer-events: auto;
  }

  .modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgb(10 9 8 / 0.78);
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out);
  }

  .modal[aria-hidden="false"] .modal__backdrop {
    opacity: 1;
  }

  .modal__panel {
    position: relative;
    z-index: 1;
    width: min(72rem, calc(100vw - 2rem));
    max-height: min(88vh, 58rem);
    display: grid;
    grid-template-rows: auto 1fr auto;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    box-shadow: 0 2rem 6rem rgb(0 0 0 / 0.45);
    overflow: hidden;
    opacity: 0;
    transform: translateY(1.5rem);
    transition:
      opacity var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out);
  }

  .modal[aria-hidden="false"] .modal__panel {
    opacity: 1;
    transform: translateY(0);
  }

  .modal__header {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-5);
    padding: var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }

  .modal__intro {
    display: grid;
    gap: var(--space-3);
  }

  .modal :global(.modal__eyebrow) {
    font-size: var(--size-xs);
    color: var(--color-accent);
  }

  .modal :global(.modal__title) {
    max-width: 13ch;
    font-size: clamp(2.5rem, 5vw, 5.5rem);
    font-weight: 700;
  }

  .modal :global(.modal__subtitle) {
    max-width: 46rem;
    color: var(--color-muted);
    font-size: var(--size-lg);
    line-height: var(--leading-snug);
  }

  .modal :global(.modal__meta-bar) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    color: var(--color-muted);
    font-size: var(--size-sm);
  }

  .modal__close {
    width: 2.5rem;
    height: 2.5rem;
    display: grid;
    place-items: center;
    color: var(--color-text);
    background: transparent;
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition:
      color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .modal__close:hover,
  .modal__close:focus-visible {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .modal__body {
    overflow-y: auto;
    padding: var(--space-6) var(--space-5);
    overscroll-behavior: contain;
  }

  .modal__body :global(.case-content) {
    display: grid;
    gap: var(--space-6);
    max-width: 52rem;
    margin: 0 auto;
  }

  .modal__body :global(h2) {
    margin-top: var(--space-2);
    font-size: var(--size-sm);
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .modal__body :global(p) {
    color: var(--color-muted);
    line-height: var(--leading-loose);
  }

  .modal__footer {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .modal__footer :global(a) {
    padding: var(--space-2) var(--space-3);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    text-decoration: none;
  }

  .modal__footer :global(a:hover) {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .modal__panel {
      width: 100vw;
      height: 100svh;
      max-height: none;
    }

    .modal__header {
      padding: var(--space-4);
    }

    .modal__body {
      padding: var(--space-5) var(--space-4);
    }
  }
</style>
