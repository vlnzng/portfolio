---
// Full-screen case-study modal (handoff cs-* design). The shell is static;
// the hero band, head (number/title/subtitle/meta) and CTAs are built by
// modal.ts from the showcase data, and the body is the MDX-rendered case.
---

<div
  class="cs-modal"
  id="showcase-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
  aria-hidden="true"
  aria-label="Case study"
  data-lenis-prevent
>
  <button class="cs-close" id="modal-close" aria-label="Close case study" type="button">&times;</button>

  <div class="cs-scroll" id="modal-scroll">
    <div class="cs-hero" id="modal-hero" aria-hidden="true"></div>
    <div class="cs-head" id="modal-meta"></div>
    <div class="cs-body">
      <div id="modal-body" tabindex="-1"></div>
      <div class="cs-cta" id="modal-footer"></div>
    </div>
  </div>
</div>

<style>
  .cs-modal {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal);
    background: var(--color-bg);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0s linear 0.4s;
  }

  .cs-modal[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.4s ease;
  }

  .cs-scroll {
    position: absolute;
    inset: 0;
    overflow-x: hidden;
    overflow-y: auto;
    overscroll-behavior: contain;
    scroll-behavior: smooth;
  }

  /* ---- open choreography: the hero image settles, then the head and the
     body rise in, the close button turning in last. Keyframes (not
     transitions) so the stagger re-plays on every open, even though the
     content is injected fresh. Closing fades the modal as one piece. ---- */
  @media (prefers-reduced-motion: no-preference) {
    .cs-modal[aria-hidden='false'] .cs-hero {
      animation: cs-hero-in 0.9s var(--ease-glide) backwards;
    }

    .cs-modal[aria-hidden='false'] .cs-head {
      animation: cs-rise-in 0.7s var(--ease-glide) 0.18s backwards;
    }

    .cs-modal[aria-hidden='false'] .cs-body {
      animation: cs-rise-in 0.8s var(--ease-glide) 0.3s backwards;
    }

    .cs-modal[aria-hidden='false'] .cs-close {
      animation: cs-close-in 0.5s var(--ease-glide) 0.4s backwards;
    }
  }

  @keyframes cs-hero-in {
    from {
      opacity: 0;
      transform: scale(1.045);
    }

    to {
      opacity: 1;
      transform: none;
    }
  }

  @keyframes cs-rise-in {
    from {
      opacity: 0;
      transform: translateY(24px);
    }

    to {
      opacity: 1;
      transform: none;
    }
  }

  @keyframes cs-close-in {
    from {
      opacity: 0;
      transform: rotate(-90deg);
    }

    to {
      opacity: 1;
      transform: none;
    }
  }

  .cs-close {
    position: fixed;
    top: 26px;
    right: 30px;
    z-index: calc(var(--z-modal) + 10);
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: rgb(26 24 22 / 0.55);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition:
      background 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .cs-close:hover,
  .cs-close:focus-visible {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
    transform: rotate(90deg);
  }

  /* hero band */
  .cs-hero {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 360px;
    overflow: hidden;
    background: var(--color-surface);
  }

  .cs-hero::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 45%;
    background: linear-gradient(0deg, var(--color-bg), rgb(26 24 22 / 0));
  }

  /* injected placeholder stripe + caption */
  .cs-hero :global(.wstripe) {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      -45deg,
      transparent 0 16px,
      rgb(155 149 144 / 0.06) 16px 32px
    );
  }

  .cs-hero :global(.wcard-cap) {
    position: absolute;
    left: 6vw;
    bottom: 24px;
    z-index: 1;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.04em;
    color: var(--color-muted);
  }

  /* head — overlaps up into the hero */
  .cs-head {
    position: relative;
    z-index: 2;
    max-width: 1180px;
    margin: -88px auto 0;
    padding: 0 6vw;
  }

  .cs-head :global(.cs-num) {
    display: block;
    margin: 0 0 14px;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }

  .cs-head :global(.cs-title) {
    max-width: 18ch;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(34px, 4.4vw, 62px);
    line-height: 1.04;
    letter-spacing: -0.015em;
    color: var(--color-text);
  }

  .cs-head :global(.cs-sub) {
    max-width: 48ch;
    margin: 22px 0 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(17px, 1.7vw, 22px);
    line-height: 1.5;
    color: #c9c2b6;
  }

  .cs-head :global(.cs-meta) {
    display: flex;
    flex-wrap: wrap;
    gap: 0 30px;
    margin: 34px 0 0;
    padding: 24px 0 0;
    border-top: 1px solid var(--color-border);
    list-style: none;
  }

  .cs-head :global(.cs-meta li) {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .cs-head :global(.cs-meta-k) {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .cs-head :global(.cs-meta-v) {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 14px;
    color: var(--color-text);
  }

  /* body — MDX-rendered case, styled as gold-headed sections */
  .cs-body {
    max-width: 760px;
    margin: 0 auto;
    padding: 9vh 6vw 13vh;
  }

  .cs-body :global(.case-content h2) {
    margin: 7.5vh 0 18px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .cs-body :global(.case-content > :first-child) {
    margin-top: 0;
  }

  .cs-body :global(.case-content h3) {
    margin: 4vh 0 14px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(20px, 1.6vw, 26px);
    color: var(--color-text);
  }

  .cs-body :global(.case-content p) {
    margin: 0 0 18px;
    max-width: none;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: clamp(17px, 1.45vw, 19px);
    line-height: 1.72;
    color: #dad3c7;
  }

  .cs-body :global(.case-content a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .cs-body :global(.case-content ul) {
    margin: 0 0 18px;
    padding-left: 1.2em;
    color: #dad3c7;
  }

  .cs-body :global(.case-content li) {
    margin: 0 0 8px;
    line-height: 1.6;
  }

  .cs-body :global(.case-content strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  /* CTAs */
  .cs-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin: 9vh 0 0;
    padding: 38px 0 0;
    border-top: 1px solid var(--color-border);
  }

  .cs-cta:empty {
    display: none;
  }

  .cs-cta :global(.cs-btn) {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    border-radius: 999px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 13.5px;
    letter-spacing: 0.04em;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.22s ease, border-color 0.22s ease, color 0.22s ease;
  }

  .cs-cta :global(.cs-btn--primary) {
    background: var(--color-accent);
    color: var(--color-bg);
    border: 1px solid var(--color-accent);
  }

  .cs-cta :global(.cs-btn--primary:hover) {
    background: #e4c384;
    border-color: #e4c384;
  }

  .cs-cta :global(.cs-btn--ghost) {
    background: none;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .cs-cta :global(.cs-btn--ghost:hover) {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 820px) {
    .cs-close {
      top: 16px;
      right: 16px;
    }

    .cs-hero {
      height: 42vh;
    }

    .cs-head {
      margin-top: -60px;
    }
  }
</style>
