---
const links = [
  { id: 'about', label: 'About' },
  { id: 'work', label: 'Work' },
  { id: 'process', label: 'Process' },
  { id: 'contact', label: 'Contact' },
];
---

<nav class="navbar" aria-label="Main navigation">
  <ul class="navbar__list">
    {links.map((link) => (
      <li>
        <a class="navbar__item" href={`/#${link.id}`} data-section-link={link.id}>
          <span>{link.label}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<div class="progress" aria-hidden="true" data-progress>
  <span class="progress__fill" data-progress-fill></span>
</div>

<style>
  .navbar {
    position: fixed;
    top: 40px;
    right: 56px;
    z-index: 60;
    pointer-events: none;
  }

  .navbar__list {
    display: flex;
    align-items: baseline;
    gap: 34px;
    margin: 0;
    padding: 0;
    list-style: none;
    pointer-events: auto;
  }

  .navbar__item {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.22s ease;
  }

  .navbar__item span {
    position: relative;
    display: inline-block;
    padding-bottom: 5px;
  }

  .navbar__item span::after {
    content: "";
    position: absolute;
    left: 0;
    right: 100%;
    bottom: 0;
    height: 1px;
    background: var(--color-accent);
    transition: right 0.28s ease;
  }

  .navbar__item:hover {
    color: var(--color-text);
  }

  /* load-in: items drop in one after another once the hero has settled */
  :global(html.js) .navbar__item {
    opacity: 0;
    translate: 0 -10px;
    transition:
      color 0.22s ease,
      opacity 0.65s ease var(--nav-d, 0.85s),
      translate 0.65s var(--ease-glide) var(--nav-d, 0.85s);
  }

  :global(html.js) li:nth-child(2) .navbar__item {
    --nav-d: 0.93s;
  }

  :global(html.js) li:nth-child(3) .navbar__item {
    --nav-d: 1.01s;
  }

  :global(html.js) li:nth-child(4) .navbar__item {
    --nav-d: 1.09s;
  }

  :global(html.js body.is-loaded) .navbar__item {
    opacity: 1;
    translate: none;
  }

  @media (prefers-reduced-motion: reduce) {
    :global(html.js) .navbar__item {
      opacity: 1;
      translate: none;
      transition: color 0.22s ease;
    }
  }

  .navbar__item:hover span::after,
  .navbar__item.is-active span::after {
    right: 0;
  }

  .navbar__item.is-active {
    color: var(--color-accent);
  }

  /* horizontal scroll progress — appears once side-panning begins */
  .progress {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    z-index: 55;
    background: rgb(217 179 108 / 0.12);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.45s ease;
  }

  .progress__fill {
    display: block;
    width: 100%;
    height: 100%;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
  }

  @media (max-width: 820px), (prefers-reduced-motion: reduce) {
    .navbar {
      top: 20px;
      right: 20px;
    }

    .navbar__list {
      gap: 18px;
    }

    .navbar__item {
      font-size: 11px;
      letter-spacing: 0.12em;
    }

    .progress {
      display: none;
    }
  }
</style>
