---
// src/components/Skills.astro
// Skills-Sektion. Finaler Inhalt folgt aus Konzept-Chat.
---

<section class="section skills" id="skills" aria-label="Skills">

  <div class="skills__inner">

    <header class="skills__header">
      <span class="skills__label">Capabilities</span>
      <h2 class="skills__heading">What I bring</h2>
    </header>

    <div class="skills__grid">

      <!-- Kategorie 1 -->
      <div class="skills__group">
        <h3 class="skills__group-title">Design</h3>
        <ul class="skills__list" role="list">
          <li>UX Research</li>
          <li>Interaction Design</li>
          <li>UI Design</li>
          <li>Prototyping</li>
          <li>Figma</li>
        </ul>
      </div>

      <!-- Kategorie 2 -->
      <div class="skills__group">
        <h3 class="skills__group-title">Development</h3>
        <ul class="skills__list" role="list">
          <li>HTML &amp; CSS</li>
          <li>JavaScript / TypeScript</li>
          <li>Astro</li>
          <li>Git / GitHub</li>
        </ul>
      </div>

      <!-- Kategorie 3 -->
      <div class="skills__group">
        <h3 class="skills__group-title">Process</h3>
        <ul class="skills__list" role="list">
          <li>Design Thinking</li>
          <li>User Research</li>
          <li>Concept Development</li>
          <li>Stakeholder Communication</li>
        </ul>
      </div>

    </div>

  </div>

</section>

<style>
  .skills {
    display: flex;
    align-items: center;
  }

  .skills__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    width: 100%;
    max-width: 800px;
  }

  .skills__label {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .skills__heading {
    font-size: var(--size-3xl);
    font-weight: 200;
    margin-top: var(--space-2);
  }

  .skills__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .skills__group-title {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: var(--space-4);
  }

  .skills__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .skills__list li {
    font-size: var(--size-base);
    line-height: 1;
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .skills__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
