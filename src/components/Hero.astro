---
// The hero panel now holds only the text block. The wordmark and the portrait
// are fixed shell elements (Wordmark.astro / SharedPortrait.astro) so they can
// morph / glide across panels, driven by scroll.ts.
---

<section class="section hero" id="hero" aria-label="Hero">
  <div class="hero-text" data-hero-text>
    <p class="hero-role">Product Designer &middot; UX/UI</p>
    <p class="hero-pitch">
      Building clear, trustworthy digital tools<br />from user research to implementation.
    </p>
    <!-- On the desktop engine the statement lives in the scroll cue (fused
         with the scroll hint, bottom centre). Here it only renders for
         mobile / reduced motion, where both phrases simply stack. -->
    <p class="hero-statement" aria-label="Learned the rules. Practising the exceptions.">
      <span class="hs-phrase">Learned the rules.</span>
      <span class="hs-phrase gold">Practising the exceptions.</span>
    </p>
  </div>
</section>

<style>
  .hero {
    padding: 0;
    background: var(--color-bg);
  }

  /* sits right below the wordmark so the left half reads as one composed
     column (wordmark → role → pitch) instead of two stranded islands */
  .hero-text {
    position: absolute;
    left: 5.5vw;
    top: 54vh;
    max-width: 640px;
    z-index: 40;
    will-change: transform;
  }

  .hero-role {
    margin: 0 0 24px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .hero-pitch {
    margin: 0;
    max-width: none;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(22px, 2.1vw, 31px);
    line-height: 1.5;
    color: var(--color-text);
  }

  .hero-statement {
    display: grid;
    gap: 2px;
    margin: 26px 0 0;
    max-width: none;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 16px;
    letter-spacing: 0.01em;
    line-height: 1.6;
    color: var(--color-muted);
  }

  .hs-phrase {
    display: block;
  }

  .hero-statement .gold {
    color: var(--color-accent);
  }

  /* On the desktop engine the statement lives in the scroll cue instead */
  @media (min-width: 821px) and (prefers-reduced-motion: no-preference) {
    .hero-statement {
      display: none;
    }
  }

  /* ---- load-in: role → pitch → statement rise on first paint ---- */
  :global(html.js) .hero-text > * {
    opacity: 0;
    transform: translateY(26px);
    transition: opacity 0.8s var(--ease-glide), transform 0.9s var(--ease-glide);
  }

  :global(html.js body.is-loaded) .hero-role {
    transition-delay: 0.35s;
  }

  :global(html.js body.is-loaded) .hero-pitch {
    transition-delay: 0.5s;
  }

  :global(html.js body.is-loaded) .hero-statement {
    transition-delay: 0.65s;
  }

  :global(html.js body.is-loaded) .hero-text > * {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    :global(html.js) .hero-text > * {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media (max-width: 820px), (prefers-reduced-motion: reduce) {
    .hero {
      min-height: 100svh;
    }

    .hero-text {
      position: absolute;
      left: 7vw;
      right: 7vw;
      top: auto;
      bottom: 10vh;
      max-width: none;
    }

    /* the fixed two-line break is a desktop composition — let it reflow */
    .hero-pitch br {
      display: none;
    }

    .hero-pitch {
      text-wrap: balance;
    }
  }
</style>
