---
---

<section class="section hero" id="hero" aria-label="Hero">
  <div class="hero__wordmark" data-hero-wordmark aria-hidden="true">
    <span>Valentin</span>
    <span>Lenzing</span>
  </div>

  <div class="hero__copy" data-hero-copy>
    <p class="hero__role">UX &amp; Product Designer</p>
    <p class="hero__pitch">
      I work at the intersection of UX research, interaction design, and front-end implementation.
    </p>
    <p class="hero__statement">
      Learned the rules.<br />
      Practising the exceptions.
    </p>
  </div>

  <figure class="hero__portrait" aria-label="Portrait placeholder">
    <div class="hero__portrait-inner">
      <span>VL</span>
    </div>
  </figure>

  <div class="hero__arrow" data-hero-arrow aria-hidden="true">↓</div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(16rem, 33vw);
    align-items: end;
    gap: var(--space-7);
    padding-top: calc(var(--section-padding) * 1.5);
  }

  .hero__wordmark {
    position: absolute;
    top: clamp(5rem, 11vh, 8rem);
    left: var(--section-padding);
    z-index: 2;
    display: flex;
    flex-direction: column;
    font-family: var(--font-display);
    font-size: clamp(4rem, 11vw, 10.5rem);
    font-weight: 700;
    line-height: 0.86;
    color: var(--color-text);
    transform-origin: left top;
  }

  .hero__copy {
    z-index: 2;
    display: grid;
    gap: var(--space-4);
    max-width: 44rem;
    padding-bottom: clamp(2rem, 8vh, 7rem);
  }

  .hero__role {
    font-size: var(--size-xl);
    color: var(--color-text);
  }

  .hero__pitch {
    font-size: clamp(1.25rem, 2vw, 2rem);
    line-height: var(--leading-snug);
    color: var(--color-muted);
  }

  .hero__statement {
    margin-top: var(--space-3);
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 4rem);
    font-weight: 700;
    line-height: 1;
    color: var(--color-text);
  }

  .hero__portrait {
    position: relative;
    align-self: stretch;
    min-height: min(72vh, 48rem);
    margin-right: calc(var(--section-padding) * -0.35);
    overflow: hidden;
    border-left: 1px solid var(--color-border);
    background:
      linear-gradient(180deg, rgb(217 179 108 / 0.16), transparent 58%),
      linear-gradient(135deg, var(--color-surface), #161412);
  }

  .hero__portrait::before {
    content: "";
    position: absolute;
    inset: 12% 12% 0;
    border: 1px solid rgb(237 230 217 / 0.22);
  }

  .hero__portrait-inner {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-size: clamp(7rem, 16vw, 16rem);
    font-weight: 700;
    color: rgb(237 230 217 / 0.1);
  }

  .hero__arrow {
    position: absolute;
    left: 50%;
    bottom: var(--space-5);
    z-index: 2;
    width: 2.25rem;
    height: 2.25rem;
    display: grid;
    place-items: center;
    color: var(--color-accent);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    transform-origin: center;
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      align-items: start;
      min-height: 100svh;
      padding-top: 7rem;
      gap: var(--space-5);
    }

    .hero__wordmark {
      position: relative;
      top: auto;
      left: auto;
      font-size: clamp(3.75rem, 18vw, 6.5rem);
    }

    .hero__copy {
      padding-bottom: 0;
    }

    .hero__portrait {
      min-height: 42vh;
      margin-right: 0;
      order: 3;
    }

    .hero__arrow {
      left: auto;
      right: var(--section-padding);
    }
  }
</style>
