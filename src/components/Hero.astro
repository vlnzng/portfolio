---
---

<section class="section hero" id="hero" aria-label="Hero">
  <h1 class="hero__wordmark" data-hero-wordmark>
    <span>Valentin</span>
    <span>Lenzing</span>
  </h1>

  <div class="hero__copy" data-hero-copy>
    <p class="hero__role">UX &amp; Product Designer</p>
    <p class="hero__pitch">
      I work at the intersection of UX research, interaction design, and front-end implementation.
    </p>
    <p class="hero__statement">
      Learned the rules.<br />
      Practising the exceptions.
    </p>
  </div>

  <figure class="hero__portrait" aria-label="Portrait of Valentin Lenzing">
    <img
      src="/images/valentin-lenzing-portrait.webp"
      alt=""
      loading="eager"
      decoding="async"
      onerror="this.hidden=true"
    />
  </figure>

  <div class="hero__arrow" data-hero-arrow aria-hidden="true">&darr;</div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(17rem, 34vw);
    align-items: end;
    gap: var(--space-7);
    padding-top: calc(var(--section-padding) * 1.5);
  }

  .hero__wordmark {
    position: absolute;
    top: clamp(5rem, 11vh, 8rem);
    left: var(--section-padding);
    z-index: 2;
    display: grid;
    font-family: var(--font-display);
    font-size: clamp(4rem, 11vw, 10.5rem);
    font-weight: 700;
    line-height: 0.86;
    letter-spacing: 0;
    color: var(--color-text);
    transform-origin: left top;
  }

  .hero__wordmark span:last-child {
    margin-top: -0.09em;
    margin-left: clamp(2rem, 7vw, 7rem);
  }

  .hero__copy {
    z-index: 2;
    display: grid;
    gap: var(--space-4);
    max-width: 44rem;
    padding-bottom: clamp(2rem, 8vh, 7rem);
  }

  .hero__role {
    font-size: var(--size-xl);
    color: var(--color-text);
  }

  .hero__pitch {
    font-size: clamp(1.25rem, 2vw, 2rem);
    line-height: var(--leading-snug);
    color: var(--color-muted);
  }

  .hero__statement {
    margin-top: var(--space-3);
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 4rem);
    font-weight: 700;
    line-height: 1;
    color: var(--color-text);
  }

  .hero__portrait {
    position: relative;
    align-self: stretch;
    min-height: min(72vh, 48rem);
    margin-right: calc(var(--section-padding) * -0.35);
    overflow: hidden;
    border-left: 1px solid var(--color-border);
    background:
      linear-gradient(180deg, rgb(217 179 108 / 0.16), transparent 58%),
      linear-gradient(135deg, var(--color-surface), #161412);
  }

  .hero__portrait::before,
  .hero__portrait::after {
    content: "";
    position: absolute;
    z-index: 2;
    pointer-events: none;
  }

  .hero__portrait::before {
    inset: 12% 12% 0;
    border: 1px solid rgb(237 230 217 / 0.22);
  }

  .hero__portrait::after {
    left: var(--space-4);
    bottom: var(--space-4);
    width: 34%;
    height: 1px;
    background: var(--color-accent);
  }

  .hero__portrait img {
    width: 100%;
    height: 100%;
    min-height: inherit;
    display: block;
    object-fit: cover;
    object-position: 50% 18%;
  }

  .hero__arrow {
    position: absolute;
    left: 50%;
    bottom: var(--space-5);
    z-index: 2;
    width: 2.25rem;
    height: 2.25rem;
    display: grid;
    place-items: center;
    color: var(--color-accent);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    transform-origin: center;
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      align-items: start;
      min-height: 100svh;
      padding-top: 7rem;
      gap: var(--space-5);
    }

    .hero__wordmark {
      position: relative;
      top: auto;
      left: auto;
      font-size: clamp(3.75rem, 18vw, 6.5rem);
    }

    .hero__copy {
      padding-bottom: 0;
    }

    .hero__portrait {
      min-height: 42vh;
      margin-right: 0;
      order: 3;
    }

    .hero__arrow {
      left: auto;
      right: var(--section-padding);
    }
  }
</style>
