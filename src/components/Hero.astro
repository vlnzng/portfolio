---
// The hero panel now holds only the text block. The wordmark and the portrait
// are fixed shell elements (Wordmark.astro / SharedPortrait.astro) so they can
// morph / glide across panels, driven by scroll.ts.
---

<section class="section hero" id="hero" aria-label="Hero">
  <div class="hero-text" data-hero-text>
    <p class="hero-role">Product Designer &middot; UX/UI</p>
    <p class="hero-pitch">
      Building clear, trustworthy digital tools from user research to frontend implementation.
    </p>
    <p class="hero-statement">
      <span class="hs-line">Learned the rules.</span>
      <span class="hs-line gold">Practising the exceptions.</span>
    </p>
  </div>
</section>

<style>
  .hero {
    padding: 0;
    background: var(--color-bg);
  }

  .hero-text {
    position: absolute;
    left: 5.5vw;
    bottom: 12vh;
    max-width: 540px;
    z-index: 40;
    will-change: transform;
  }

  .hero-role {
    margin: 0 0 22px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .hero-pitch {
    margin: 0 0 26px;
    max-width: none;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(22px, 2vw, 28px);
    line-height: 1.5;
    color: var(--color-text);
  }

  .hero-statement {
    display: grid;
    gap: 2px;
    margin: 0;
    max-width: none;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 16px;
    letter-spacing: 0.01em;
    line-height: 1.6;
    color: var(--color-muted);
  }

  .hero-statement .gold {
    color: var(--color-accent);
  }

  @media (max-width: 820px), (prefers-reduced-motion: reduce) {
    .hero {
      min-height: 100svh;
    }

    .hero-text {
      position: absolute;
      left: 7vw;
      right: 7vw;
      bottom: 10vh;
      max-width: none;
    }
  }
</style>
