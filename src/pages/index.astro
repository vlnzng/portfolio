---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Wordmark from '../components/Wordmark.astro';
import SharedPortrait from '../components/SharedPortrait.astro';
import ScrollCue from '../components/ScrollCue.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import ShowcaseCard from '../components/ShowcaseCard.astro';
import ShowcaseModal from '../components/ShowcaseModal.astro';
import Process from '../components/Process.astro';
import Contact from '../components/Contact.astro';

import { getCollection, render } from 'astro:content';

interface Props {
  initialModalSlug?: string;
}

const { initialModalSlug } = Astro.props;

const showcases = (await getCollection('showcases')).sort((a, b) => a.data.order - b.data.order);
const getSlug = (id: string) => id.replace(/\.mdx$/, '').split('/').pop() ?? id;
const renderedShowcases = await Promise.all(
  showcases.map(async (showcase) => {
    const { Content } = await render(showcase);
    return { showcase, Content };
  }),
);

const showcaseData = showcases.map((showcase) => ({
  slug: getSlug(showcase.id),
  order: showcase.data.order,
  title: showcase.data.title,
  subtitle: showcase.data.subtitle,
  summary: showcase.data.summary,
  heroCaption: showcase.data.heroCaption,
  year: showcase.data.year,
  role: showcase.data.role,
  type: showcase.data.type,
  duration: showcase.data.duration,
  tools: showcase.data.tools,
  tags: showcase.data.tags,
  externalLink: showcase.data.externalLink,
  githubLink: showcase.data.githubLink,
}));
---

<BaseLayout initialModalSlug={initialModalSlug}>
  <Navigation />
  <Wordmark />
  <SharedPortrait />
  <ScrollCue />

  <div class="scroll-container">
    <div class="horizontal-track">
      <Hero />
      <About />

      <section class="section work" id="work" aria-label="Work">
        <div class="work-inner">
          <h2 class="sr-only">Work</h2>

          <div class="work-row">
            {showcases.map((showcase) => <ShowcaseCard showcase={showcase} />)}
          </div>
        </div>
      </section>

      <Process />
      <Contact />
    </div>
  </div>

  <div class="case-templates" hidden>
    {renderedShowcases.map(({ showcase, Content }) => (
      <template id={`case-template-${getSlug(showcase.id)}`}>
        <div class="case-content">
          <Content />
        </div>
      </template>
    ))}
  </div>

  <script type="application/json" id="showcase-data" set:html={JSON.stringify(showcaseData)}></script>

  <ShowcaseModal />
</BaseLayout>

<script>
  import '../scripts/reveal';
  import '../scripts/scroll';
  import '../scripts/modal';
  import '../scripts/navigation';
</script>

<style>
  .work {
    width: 100vw;
    padding: 0;
    background: var(--color-bg);
  }

  .work-inner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 5.5vw;
  }

  /* enumeration row — four uniform image-top cards on one level */
  .work-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(22px, 2.3vw, 50px);
    width: 100%;
    align-items: start;
  }

  @media (max-width: 820px), (prefers-reduced-motion: reduce) {
    .work-inner {
      position: static;
      display: block;
      padding: 16vh 7vw 12vh;
    }

    .work-row {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
