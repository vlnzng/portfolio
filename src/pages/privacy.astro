---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy | Valentin Lenzing">
  <section class="legal-page">
    <a href="/#contact" class="legal-page__back">Back</a>
    <h1>Privacy</h1>
    <p>
      This page is reserved for the privacy policy. The current V1 does not add analytics or tracking cookies.
      Final hosting, contact, and data processing details need to be added before launch.
    </p>
    <p>Email: hello@valentin-lenzing.de</p>
  </section>
</BaseLayout>

<style>
  .legal-page {
    min-height: 100svh;
    display: grid;
    align-content: center;
    gap: var(--space-4);
    padding: var(--section-padding);
    max-width: 52rem;
  }

  .legal-page__back {
    width: fit-content;
    color: var(--color-accent);
  }

  h1 {
    font-size: clamp(3rem, 8vw, 7rem);
  }

  p {
    color: var(--color-muted);
    line-height: var(--leading-loose);
  }
</style>
