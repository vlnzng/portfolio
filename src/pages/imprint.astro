---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Legal Notice | Valentin Lenzing">
  <article class="legal">
    <a href="/#contact" class="legal__back">← Back</a>

    <!-- German is the legally authoritative version. -->
    <h1>Impressum</h1>
    <p class="legal__sub">
      Angaben gemäß § 5 DDG · <em>Platzhalter — vor Veröffentlichung vervollständigen.</em>
    </p>

    <h3>Diensteanbieter</h3>
    <p>
      Valentin Lenzing<br />
      [Straße &amp; Hausnummer]<br />
      [PLZ Ort], Deutschland
    </p>

    <h3>Kontakt</h3>
    <p>E-Mail: <a href="mailto:valentin.lenzing@gmail.com">valentin.lenzing@gmail.com</a></p>

    <h3>Verantwortlich für den Inhalt nach § 18 Abs. 2 MStV</h3>
    <p>Valentin Lenzing, Anschrift wie oben.</p>

    <p class="legal__note">
      Privates, nicht-kommerzielles Portfolio. Diese Fassung ist ein Platzhalter; finale Angaben
      und eine rechtliche Prüfung folgen vor dem Launch.
    </p>

    <hr class="legal__divider" />

    <!-- English version — the German text above prevails. -->
    <h2>Legal Notice (English)</h2>
    <p class="legal__sub">Provider information pursuant to § 5 DDG. The German version above is legally authoritative.</p>

    <h3>Provider</h3>
    <p>
      Valentin Lenzing<br />
      [Street &amp; number]<br />
      [Postal code, City], Germany
    </p>

    <h3>Contact</h3>
    <p>Email: <a href="mailto:valentin.lenzing@gmail.com">valentin.lenzing@gmail.com</a></p>

    <p class="legal__note">
      Private, non-commercial portfolio. Placeholder — final details and a legal review will
      follow before launch.
    </p>
  </article>
</BaseLayout>

<style>
  .legal {
    max-width: 48rem;
    margin: 0 auto;
    padding: calc(var(--space-8) + 2rem) var(--section-padding) var(--space-8);
  }

  .legal__back {
    display: inline-block;
    margin-bottom: var(--space-6);
    color: var(--color-accent);
  }

  .legal h1 {
    font-size: clamp(2.4rem, 6vw, 4rem);
    margin: 0 0 var(--space-2);
  }

  .legal h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    margin: 0 0 var(--space-2);
  }

  .legal h3 {
    font-size: var(--size-lg);
    color: var(--color-text);
    margin: var(--space-5) 0 var(--space-2);
  }

  .legal__sub {
    color: var(--color-muted);
    margin: 0 0 var(--space-5);
  }

  .legal p {
    color: var(--color-muted);
    line-height: var(--leading-loose);
    margin: 0 0 var(--space-3);
  }

  .legal a {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .legal a:hover {
    color: var(--color-accent);
  }

  .legal__note {
    border-left: 2px solid var(--color-accent);
    padding-left: var(--space-3);
    font-size: var(--size-sm);
  }

  .legal__divider {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: var(--space-7) 0;
  }
</style>
