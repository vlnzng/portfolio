---
// src/pages/work/[slug].astro
// Dynamic route for direct modal URLs: /work/fair-monetisation
// Renders the home page with the modal open on load.

import { getCollection } from 'astro:content';
import HomePage from '../index.astro';

export async function getStaticPaths() {
  const showcases = await getCollection('showcases');
  return showcases.map((showcase) => ({
    params: { slug: showcase.id.replace(/\.mdx$/, '').split('/').pop() ?? showcase.id },
  }));
}

const { slug } = Astro.params;
---

<HomePage initialModalSlug={slug} />
